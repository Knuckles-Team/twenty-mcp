# Twenty CRM Base Server URL
TWENTY_URL=http://localhost:3000
# Developer authentication token
TWENTY_TOKEN=twenty_developer_access_token
# Base API URL to query
TWENTY_MCP_BASE_URL=http://localhost:3000/api
# Auth username for service
TWENTY_MCP_USERNAME=admin
# Auth password for service
TWENTY_MCP_PASSWORD=secure_password
# SSL verification flag
TWENTY_MCP_SSL_VERIFY=True
# CRM Tool Enabled Flag
CRMTOOL=True
